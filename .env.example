# .env 範本 — 複製此檔並重新命名為 .env，填入您的 API 金鑰
GEMINI_API_KEY=your_gemini_api_key_here

# postgresql neon雲端url
DATABASE_URL=your postgresql

# pinecone api key
PINECONE_API_KEY=your_pinecone_api_key_here

# pinecone index 名稱（預設 chatstar）
PINECONE_INDEX=chatstar

# pinecone dedicated host（可選，serverless 可留空）
# PINECONE_HOST=https://xxx-yyy.svc.aped-xxx.pinecone.io

# embedding model 設定（配合 Pinecone Inference API）
EMBED_MODEL=multilingual-e5-large
EMBED_DIM=1024